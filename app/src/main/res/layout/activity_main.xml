<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Header -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="8dp">

            <TextView
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:text="Philips MMS8085B"
                android:textColor="#E0E0E0"
                android:textSize="18sp"
                android:textStyle="bold"/>

            <Button
                android:id="@+id/btnSetup"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="⚙ Setup"
                android:textSize="12sp"
                android:backgroundTint="#2A2D36"
                android:textColor="#E0E0E0"/>
        </LinearLayout>

        <!-- Status -->
        <TextView
            android:id="@+id/tvStatus"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Checking IR..."
            android:textColor="#90CAF9"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- POWER + MUTE row -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1E2128"
            app:cardCornerRadius="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="16dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btnPower"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="⏻ POWER"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#C62828"/>

                <Button
                    android:id="@+id/btnMute"
                    android:layout_width="0dp"
                    android:layout_height="64dp"
                    android:layout_weight="1"
                    android:layout_marginStart="8dp"
                    android:text="🔇 MUTE"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#37474F"/>

            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- SOURCE BUTTONS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1E2128"
            app:cardCornerRadius="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOURCE"
                    android:textColor="#90CAF9"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBT"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="BT"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#1565C0"/>

                    <Button
                        android:id="@+id/btnAux"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="AUX"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#2E7D32"/>

                    <Button
                        android:id="@+id/btnFM"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="6dp"
                        android:text="FM"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#6A1B9A"/>

                    <Button
                        android:id="@+id/btnUSB"
                        android:layout_width="0dp"
                        android:layout_height="52dp"
                        android:layout_weight="1"
                        android:text="USB"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#E65100"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- VOLUME -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="12dp"
            app:cardBackgroundColor="#1E2128"
            app:cardCornerRadius="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="VOLUME"
                    android:textColor="#90CAF9"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnVolDown"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="VOL −"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:backgroundTint="#263238"/>

                    <Button
                        android:id="@+id/btnVolUp"
                        android:layout_width="0dp"
                        android:layout_height="72dp"
                        android:layout_weight="1"
                        android:text="VOL +"
                        android:textColor="#FFFFFF"
                        android:textSize="18sp"
                        android:backgroundTint="#263238"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- BASS -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="24dp"
            app:cardBackgroundColor="#1E2128"
            app:cardCornerRadius="16dp"
            xmlns:app="http://schemas.android.com/apk/res-auto">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="16dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="BASS"
                    android:textColor="#90CAF9"
                    android:textSize="11sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.1"
                    android:layout_marginBottom="10dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBassDown"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="BASS −"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:backgroundTint="#4A148C"/>

                    <Button
                        android:id="@+id/btnBassUp"
                        android:layout_width="0dp"
                        android:layout_height="56dp"
                        android:layout_weight="1"
                        android:text="BASS +"
                        android:textColor="#FFFFFF"
                        android:textSize="14sp"
                        android:backgroundTint="#4A148C"/>

                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- Footer hint -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Point IR at subwoofer front panel  •  Tap ⚙ Setup if buttons don't respond"
            android:textColor="#546E7A"
            android:textSize="11sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
