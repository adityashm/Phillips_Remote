<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318"
    android:fillViewport="true">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="14dp">

        <!-- ── Header ──────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:gravity="center_vertical"
            android:layout_marginBottom="4dp">

            <LinearLayout
                android:layout_width="0dp"
                android:layout_height="wrap_content"
                android:layout_weight="1"
                android:orientation="vertical">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="Philips MMS8085B"
                    android:textColor="#E0E0E0"
                    android:textSize="18sp"
                    android:textStyle="bold"/>

                <TextView
                    android:id="@+id/tvStatus"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Checking IR..."
                    android:textColor="#90CAF9"
                    android:textSize="11sp"
                    android:layout_marginTop="2dp"/>
            </LinearLayout>

            <Button
                android:id="@+id/btnSetup"
                android:layout_width="wrap_content"
                android:layout_height="36dp"
                android:text="⚙ Setup"
                android:textSize="12sp"
                android:backgroundTint="#2A2D36"
                android:textColor="#E0E0E0"/>
        </LinearLayout>

        <!-- ── Power + Mute ─────────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#1E2128"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="horizontal"
                android:padding="14dp"
                android:gravity="center">

                <Button
                    android:id="@+id/btnPower"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:layout_marginEnd="8dp"
                    android:text="⏻  POWER"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#C62828"/>

                <Button
                    android:id="@+id/btnMute"
                    android:layout_width="0dp"
                    android:layout_height="60dp"
                    android:layout_weight="1"
                    android:text="🔇  MUTE"
                    android:textColor="#FFFFFF"
                    android:textSize="14sp"
                    android:backgroundTint="#37474F"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Source buttons ───────────────────────────────────────────── -->
        <androidx.cardview.widget.CardView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            app:cardBackgroundColor="#1E2128"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="SOURCE"
                    android:textColor="#90CAF9"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="8dp"/>

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnBT"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="BT"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#1565C0"/>

                    <Button
                        android:id="@+id/btnAux"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="AUX"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#2E7D32"/>

                    <Button
                        android:id="@+id/btnFM"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="5dp"
                        android:text="FM"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#6A1B9A"/>

                    <Button
                        android:id="@+id/btnUSB"
                        android:layout_width="0dp"
                        android:layout_height="48dp"
                        android:layout_weight="1"
                        android:text="USB"
                        android:textColor="#FFFFFF"
                        android:textSize="12sp"
                        android:backgroundTint="#E65100"/>
                </LinearLayout>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Mode tabs ─────────────────────────────────────────────────── -->
        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="horizontal"
            android:layout_marginBottom="10dp"
            android:background="#1E2128"
            android:padding="4dp">

            <Button
                android:id="@+id/tabAudio"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:text="🔊 AUDIO"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#1565C0"/>

            <Button
                android:id="@+id/tabPlayback"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:layout_marginEnd="2dp"
                android:text="▶ PLAY"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A2D36"/>

            <Button
                android:id="@+id/tabNumpad"
                android:layout_width="0dp"
                android:layout_height="40dp"
                android:layout_weight="1"
                android:text="🔢 NUMPAD"
                android:textSize="11sp"
                android:textColor="#FFFFFF"
                android:backgroundTint="#2A2D36"/>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PANEL: AUDIO (VOL + BASS)                                     -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <LinearLayout
            android:id="@+id/panelAudio"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:visibility="visible">

            <!-- Volume -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2128"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="VOLUME  (hold for continuous)"
                        android:textColor="#90CAF9"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnVolDown"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="VOL −"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:backgroundTint="#263238"/>

                        <Button
                            android:id="@+id/btnVolUp"
                            android:layout_width="0dp"
                            android:layout_height="80dp"
                            android:layout_weight="1"
                            android:text="VOL +"
                            android:textColor="#FFFFFF"
                            android:textSize="20sp"
                            android:textStyle="bold"
                            android:backgroundTint="#263238"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>

            <!-- Bass -->
            <androidx.cardview.widget.CardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="10dp"
                app:cardBackgroundColor="#1E2128"
                app:cardCornerRadius="16dp">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="14dp">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="BASS  (hold for continuous)"
                        android:textColor="#90CAF9"
                        android:textSize="10sp"
                        android:textStyle="bold"
                        android:letterSpacing="0.12"
                        android:layout_marginBottom="8dp"/>

                    <LinearLayout
                        android:layout_width="match_parent"
                        android:layout_height="wrap_content"
                        android:orientation="horizontal">

                        <Button
                            android:id="@+id/btnBassDown"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:layout_marginEnd="8dp"
                            android:text="BASS −"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:backgroundTint="#4A148C"/>

                        <Button
                            android:id="@+id/btnBassUp"
                            android:layout_width="0dp"
                            android:layout_height="56dp"
                            android:layout_weight="1"
                            android:text="BASS +"
                            android:textColor="#FFFFFF"
                            android:textSize="14sp"
                            android:backgroundTint="#4A148C"/>
                    </LinearLayout>
                </LinearLayout>
            </androidx.cardview.widget.CardView>
        </LinearLayout>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PANEL: PLAYBACK (Play/Pause, Next, Prev)                      -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/panelPlayback"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1E2128"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="PLAYBACK  (USB / Bluetooth)"
                    android:textColor="#90CAF9"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="12dp"/>

                <!-- Play/Pause large -->
                <Button
                    android:id="@+id/btnPlayPause"
                    android:layout_width="match_parent"
                    android:layout_height="88dp"
                    android:text="▶⏸  PLAY / PAUSE"
                    android:textColor="#FFFFFF"
                    android:textSize="20sp"
                    android:textStyle="bold"
                    android:backgroundTint="#00695C"
                    android:layout_marginBottom="12dp"/>

                <!-- Prev / Next -->
                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal">

                    <Button
                        android:id="@+id/btnPrev"
                        android:layout_width="0dp"
                        android:layout_height="68dp"
                        android:layout_weight="1"
                        android:layout_marginEnd="8dp"
                        android:text="⏮  PREV"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:backgroundTint="#1A237E"/>

                    <Button
                        android:id="@+id/btnNext"
                        android:layout_width="0dp"
                        android:layout_height="68dp"
                        android:layout_weight="1"
                        android:text="NEXT  ⏭"
                        android:textColor="#FFFFFF"
                        android:textSize="16sp"
                        android:backgroundTint="#1A237E"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="Switch source to USB or BT first, then use playback controls"
                    android:textColor="#546E7A"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ═══════════════════════════════════════════════════════════════ -->
        <!-- PANEL: NUMPAD (0–9)                                           -->
        <!-- ═══════════════════════════════════════════════════════════════ -->
        <androidx.cardview.widget.CardView
            android:id="@+id/panelNumpad"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:layout_marginBottom="10dp"
            android:visibility="gone"
            app:cardBackgroundColor="#1E2128"
            app:cardCornerRadius="16dp">

            <LinearLayout
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:orientation="vertical"
                android:padding="14dp">

                <TextView
                    android:layout_width="wrap_content"
                    android:layout_height="wrap_content"
                    android:text="NUMERIC  (USB track select / FM frequency)"
                    android:textColor="#90CAF9"
                    android:textSize="10sp"
                    android:textStyle="bold"
                    android:letterSpacing="0.12"
                    android:layout_marginBottom="10dp"/>

                <!-- Row 1: 1 2 3 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <Button android:id="@+id/btnNum1"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:text="1"
                        android:textSize="20sp" android:textColor="#FFFFFF" android:backgroundTint="#1A237E"/>
                    <Button android:id="@+id/btnNum2"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:text="2"
                        android:textSize="20sp" android:textColor="#FFFFFF" android:backgroundTint="#1A237E"/>
                    <Button android:id="@+id/btnNum3"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:text="3" android:textSize="20sp" android:textColor="#FFFFFF"
                        android:backgroundTint="#1A237E"/>
                </LinearLayout>

                <!-- Row 2: 4 5 6 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <Button android:id="@+id/btnNum4"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:text="4"
                        android:textSize="20sp" android:textColor="#FFFFFF" android:backgroundTint="#1A237E"/>
                    <Button android:id="@+id/btnNum5"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:text="5"
                        android:textSize="20sp" android:textColor="#FFFFFF" android:backgroundTint="#1A237E"/>
                    <Button android:id="@+id/btnNum6"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:text="6" android:textSize="20sp" android:textColor="#FFFFFF"
                        android:backgroundTint="#1A237E"/>
                </LinearLayout>

                <!-- Row 3: 7 8 9 -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal" android:layout_marginBottom="6dp">
                    <Button android:id="@+id/btnNum7"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:text="7"
                        android:textSize="20sp" android:textColor="#FFFFFF" android:backgroundTint="#1A237E"/>
                    <Button android:id="@+id/btnNum8"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:text="8"
                        android:textSize="20sp" android:textColor="#FFFFFF" android:backgroundTint="#1A237E"/>
                    <Button android:id="@+id/btnNum9"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:text="9" android:textSize="20sp" android:textColor="#FFFFFF"
                        android:backgroundTint="#1A237E"/>
                </LinearLayout>

                <!-- Row 4: [spacer] 0 [spacer] -->
                <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
                    android:orientation="horizontal">
                    <View android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp"/>
                    <Button android:id="@+id/btnNum0"
                        android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"
                        android:layout_marginEnd="5dp" android:text="0"
                        android:textSize="20sp" android:textColor="#FFFFFF" android:backgroundTint="#1A237E"/>
                    <View android:layout_width="0dp" android:layout_height="60dp" android:layout_weight="1"/>
                </LinearLayout>

                <TextView
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:text="USB: enter track number  •  FM: enter frequency digits"
                    android:textColor="#546E7A"
                    android:textSize="11sp"
                    android:gravity="center"
                    android:layout_marginTop="10dp"/>
            </LinearLayout>
        </androidx.cardview.widget.CardView>

        <!-- ── Footer hint ───────────────────────────────────────────────── -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Point IR at subwoofer front panel  •  Vol/Bass: hold for continuous  •  Tap ⚙ Setup if no response"
            android:textColor="#37474F"
            android:textSize="10sp"
            android:gravity="center"
            android:layout_marginBottom="8dp"/>

    </LinearLayout>
</ScrollView>
