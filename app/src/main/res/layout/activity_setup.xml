<?xml version="1.0" encoding="utf-8"?>
<ScrollView xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:background="#111318">

    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="vertical"
        android:padding="16dp">

        <!-- Title -->
        <TextView
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="⚙  IR Code Setup"
            android:textColor="#90CAF9"
            android:textSize="20sp"
            android:textStyle="bold"
            android:layout_marginBottom="4dp"/>

        <TextView
            android:id="@+id/tvInstruction"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:text="Follow the steps below to find your MMS8085B's IR codes."
            android:textColor="#B0BEC5"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- ── Protocol selector ─────────────────────────────────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="STEP 1: SELECT PROTOCOL" android:textColor="#90CAF9"
            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <TextView android:id="@+id/tvProtocol"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Protocol: NEC @ 38 kHz  ◀ Try this first for MMS8085B"
            android:textColor="#FFF176" android:textSize="12sp"
            android:layout_marginBottom="8dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="20dp">
            <Button android:id="@+id/btnProtocolNec"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="NEC (38 kHz)" android:textSize="11sp"
                android:backgroundTint="#1565C0" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnProtocolRc5"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp"
                android:text="RC-5 (36 kHz)" android:textSize="11sp"
                android:backgroundTint="#37474F" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnProtocolRc6"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="RC-6 (36 kHz)" android:textSize="11sp"
                android:backgroundTint="#37474F" android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- ── Scan buttons ──────────────────────────────────────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="STEP 2: FIND ADDRESS  (point IR at subwoofer, watch for vol change)"
            android:textColor="#90CAF9"
            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <!-- Quick Scan -->
        <Button
            android:id="@+id/btnQuickScan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="▶  Quick Scan — 25 addresses  (~37 sec)"
            android:backgroundTint="#1565C0"
            android:textColor="#FFFFFF"
            android:textSize="13sp"
            android:layout_marginBottom="6dp"/>

        <!-- Deep Scan -->
        <Button
            android:id="@+id/btnDeepScan"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔬  Deep Scan — ALL 256 addresses  (~6.5 min, guaranteed)"
            android:backgroundTint="#4A148C"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="6dp"/>

        <!-- Progress bar -->
        <ProgressBar
            android:id="@+id/progressBar"
            style="@android:style/Widget.ProgressBar.Horizontal"
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:max="100"
            android:visibility="gone"
            android:layout_marginBottom="16dp"/>

        <!-- ── Manual sliders ────────────────────────────────────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="STEP 3: FINE-TUNE (manual address + command sliders)"
            android:textColor="#90CAF9"
            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <TextView android:id="@+id/tvAddrVal"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Address: 0  (0x0)" android:textColor="#E0E0E0" android:textSize="13sp"/>
        <SeekBar android:id="@+id/seekAddr"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="255" android:progress="0" android:layout_marginBottom="10dp"/>

        <TextView android:id="@+id/tvCmdVal"
            android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="Command: 70  (0x46)" android:textColor="#E0E0E0" android:textSize="13sp"/>
        <SeekBar android:id="@+id/seekCmd"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:max="255" android:progress="70" android:layout_marginBottom="10dp"/>

        <TextView android:id="@+id/tvCurrentCode"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Will send → Addr:0 Cmd:70"
            android:textColor="#FFF176" android:textSize="13sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="10dp"/>

        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btnSendTest"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:layout_marginEnd="8dp"
                android:text="📡  Send Test" android:backgroundTint="#37474F" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnConfirm"
                android:layout_width="0dp" android:layout_height="52dp" android:layout_weight="1"
                android:text="✔  Confirm Code" android:backgroundTint="#2E7D32" android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- ── Command Sweep ─────────────────────────────────────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="STEP 4: COMMAND SWEEP  (once address confirmed)"
            android:textColor="#90CAF9"
            android:textSize="10sp" android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="6dp"/>

        <Button
            android:id="@+id/btnCmdSweep"
            android:layout_width="match_parent"
            android:layout_height="52dp"
            android:text="🔍  Command Sweep — all 256 cmds for selected button"
            android:backgroundTint="#BF360C"
            android:textColor="#FFFFFF"
            android:textSize="12sp"
            android:layout_marginBottom="16dp"/>

        <!-- ── Button target selector ─────────────────────────────────────── -->
        <TextView android:layout_width="wrap_content" android:layout_height="wrap_content"
            android:text="STEP 4b: SELECT WHICH BUTTON TO CONFIGURE"
            android:textColor="#90CAF9" android:textSize="10sp"
            android:textStyle="bold" android:letterSpacing="0.1"
            android:layout_marginBottom="8dp"/>

        <!-- Row: Power / Vol+ / Vol- / Mute -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="5dp">
            <Button android:id="@+id/btnTargetPower"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="Power"
                android:textSize="11sp" android:backgroundTint="#C62828" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetVolUp"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="Vol+"
                android:textSize="11sp" android:backgroundTint="#263238" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetVolDown"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="Vol-"
                android:textSize="11sp" android:backgroundTint="#263238" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetMute"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="Mute"
                android:textSize="11sp" android:backgroundTint="#37474F" android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Row: Bass+ / Bass- / BT / AUX -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="5dp">
            <Button android:id="@+id/btnTargetBassUp"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="Bass+"
                android:textSize="11sp" android:backgroundTint="#4A148C" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetBassDown"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="Bass-"
                android:textSize="11sp" android:backgroundTint="#4A148C" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetBT"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="BT"
                android:textSize="11sp" android:backgroundTint="#1565C0" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetAux"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="AUX"
                android:textSize="11sp" android:backgroundTint="#2E7D32" android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- Row: FM / USB / ▶⏸ / ⏭ / ⏮ -->
        <LinearLayout android:layout_width="match_parent" android:layout_height="wrap_content"
            android:orientation="horizontal" android:layout_marginBottom="16dp">
            <Button android:id="@+id/btnTargetFM"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="FM"
                android:textSize="11sp" android:backgroundTint="#6A1B9A" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetUSB"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="USB"
                android:textSize="11sp" android:backgroundTint="#E65100" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetPlay"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="▶⏸"
                android:textSize="14sp" android:backgroundTint="#00695C" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetPrev"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:layout_marginEnd="4dp" android:text="⏮"
                android:textSize="14sp" android:backgroundTint="#1A237E" android:textColor="#FFFFFF"/>
            <Button android:id="@+id/btnTargetNext"
                android:layout_width="0dp" android:layout_height="44dp" android:layout_weight="1"
                android:text="⏭"
                android:textSize="14sp" android:backgroundTint="#1A237E" android:textColor="#FFFFFF"/>
        </LinearLayout>

        <!-- ── Saved codes summary ────────────────────────────────────────── -->
        <TextView android:id="@+id/tvSavedCodes"
            android:layout_width="match_parent" android:layout_height="wrap_content"
            android:text="Saved codes: (loading...)"
            android:textColor="#78909C" android:textSize="11sp"
            android:fontFamily="monospace"
            android:layout_marginBottom="16dp"/>

        <!-- ── Save button ────────────────────────────────────────────────── -->
        <Button android:id="@+id/btnSave"
            android:layout_width="match_parent" android:layout_height="56dp"
            android:text="💾  Save All &amp; Return to Remote"
            android:backgroundTint="#00695C" android:textColor="#FFFFFF"
            android:textSize="15sp"
            android:layout_marginBottom="16dp"/>

    </LinearLayout>
</ScrollView>
